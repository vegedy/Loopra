<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".ui.editor.EditorFragment">

    <EditText
        android:id="@+id/edit_code"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/surface_dark"
        android:fontFamily="monospace"
        android:gravity="start|top"
        android:hint="@string/editor_code_hint"
        android:inputType="textMultiLine|textNoSuggestions"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:textColor="@color/terminal_text"
        android:textColorHint="@color/disabled"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintBottom_toTopOf="@id/linear_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/linear_controls"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toTopOf="@id/linear_output_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/button_run"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_run" />

        <Button
            android:id="@+id/button_clear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_stop" />

        <Button
            android:id="@+id/button_debug"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_debug" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linear_output_header"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:background="@color/surface_variant_dark"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toTopOf="@id/text_output"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/editor_output_label"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/text_output"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@color/terminal_bg"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/text_output_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/terminal_text"
            android:textSize="13sp" />
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
